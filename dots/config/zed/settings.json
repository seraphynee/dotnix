{
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    }
  },

  "agent": {
    "default_model": {
      "provider": "zed.dev",
      "model": "gpt-5.4",
      "enable_thinking": true,
      "effort": "medium"
    },
    "favorite_models": [],
    "model_parameters": []
  },

  "focus_follows_mouse": {
    "enabled": true
  },

  "show_edit_predictions": false,

  "theme": "Vitesse Refined Dark",
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Macchiato",
    "dark": "Catppuccin Macchiato"
  },

  "which_key": { "enabled": true, "delay_ms": 50 },

  "vertical_scroll_margin": 0,

  "agent_buffer_font_size": 17.0,
  "colorize_brackets": true,
  "terminal": {
    "default_height": 480,
    "font_size": 18
  },
  "ui_font_family": "Geist Mono",
  "ui_font_size": 18,
  "buffer_font_family": "Geist Mono",
  "buffer_font_size": 16,
  "scrollbar": {
    "show": "never"
  },
  "scroll_beyond_last_line": "off",

  "base_keymap": "VSCode",
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "relative_line_numbers": "enabled",
  "cursor_blink": false,

  "auto_install_extensions": {
    "dockerfile": true,
    "html": true,
    "sql": true,
    "java": true,
    "nix": true,
    "lua": true,
    "make": true,
    "latex": true,
    "prisma": true,
    "biome": true,
    "astro": true,
    "vue": true,
    "markdown-oxide": true,
    "wakatime": true,
    "tombi": false,
    "fish": true,

    "mcp-server-context7": true,
    "postgres-context-server": true,
    "mcp-server-github": true,
    "mcp-server-exa-search": true,
    "mcp-server-firecrawl": true,
    "prisma-mcp": true,
    "mcp-server-resend": true,
    "mcp-server-buildkite": true,
    "shadcn-mcp": true,

    "catppuccin-blur": true,
    "vitesse-theme-refined": true,

    "catppuccin-icons": true,
    "jetbrains-new-ui-icons": true,
    "colored-zed-icons-theme": true,

    "react-typescript-snippets": true,
    "python-snippets": true,
    "go-snippets": true,
    "nextjs-react-snippets": true
  },

  "enable_language_server": true,

  "autosave": "on_focus_change",
  "close_on_file_delete": true,
  "hide_mouse": "on_typing_and_movement",
  "format_on_save": "on",
  "minimap": {
    "show": "never",
    "thumb": "always",
    "thumb_border": "left_open",
    "current_line_highlight": null
  },

  "languages": {
    "Nix": {
      "language_servers": ["nil", "!nixd"]
    }
  },

  "lsp": {
    "wakatime": {
      "initialization_options": {
        "api-key": "{{ if .use_secrets }}{{ onepasswordRead .secrets.productivity.wakatime_apikey }}{{ end }}"
      }
    },
    "nil": {
      "initialization_options": {
        "formatting": {
          "command": ["nixfmt", "--quiet", "--"]
        }
      }
    }
  }
}
